# Database
DATABASE_URL="postgresql://readlingo:readlingo@localhost:5432/readlingo?schema=public"

# Auth
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Leave NEXTAUTH_URL unset in local development so Auth.js can infer the
# current dev server origin for OAuth callbacks.
# NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Uploads
UPLOAD_DIR="./uploads"

# AI Providers
AI_PROVIDER="google"
GITHUB_TOKEN=""
GOOGLE_GENERATIVE_AI_API_KEY=""
QWEN_API_KEY=""
QWEN_BASE_URL="https://your-qwen-openai-compatible-endpoint"
